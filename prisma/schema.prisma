// Prisma schema — приложение ZenAir КП.
// На Этапе 0 только Manager; остальные модели добавляем по мере этапов (см. PLAN.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Manager {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}
